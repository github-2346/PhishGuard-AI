

# Neon DB PostgreSQL Connection
# Get this from: https://console.neon.tech → Your Project → Connection Details
DB_URL=jdbc:postgresql://YOUR_HOST.neon.tech/neondb?sslmode=require
DB_USERNAME=YOUR_NEON_USERNAME
DB_PASSWORD=YOUR_NEON_PASSWORD

# JWT Secret
# Change this to any long random string (min 32 chars)
JWT_SECRET=PhishGuardSuperSecretKeyForJWTGeneration2026!@#$%^&*()
JWT_EXPIRATION=86400000

# Security APIs 
# Get free VirusTotal API key from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_API_KEY
# Get Google Safe Browsing key from: https://console.cloud.google.com
GOOGLE_SB_API_KEY=YOUR_GOOGLE_SB_API_KEY

# CORS Origins
# Add your deployed frontend URL here when deploying
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Port
PORT=8080
